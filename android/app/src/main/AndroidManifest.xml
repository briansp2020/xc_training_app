<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed for server sync and OpenStreetMap map tiles. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Health Connect read permissions.
         Note: the health package reads TotalCaloriesBurnedRecord (not Active) when
         aggregating workout calories, so READ_TOTAL_CALORIES_BURNED is required
         for workout reads to return anything. -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE"/>
    <uses-permission android:name="android.permission.health.READ_STEPS"/>
    <uses-permission android:name="android.permission.health.READ_DISTANCE"/>
    <uses-permission android:name="android.permission.health.READ_SLEEP"/>
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED"/>
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED"/>
    <uses-permission android:name="android.permission.health.READ_EXERCISE"/>
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY"/>
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE"/>
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE"/>
    <!-- GPS routes other apps (Fitbit, Pixel Watch) attach to their workouts.
         Reading routes written by OTHER apps additionally needs a one-time
         "Exercise routes → Always allow" grant in Health Connect's app
         permissions — the normal permission dialog isn't enough; until then
         those routes come back empty (ConsentRequired). -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE_ROUTE"/>
    <!-- Blanket "Exercise routes" permission (Android 15+). Requested via the
         native MethodChannel in MainActivity — the health plugin can't. -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE_ROUTES"/>

    <!-- GPS route recording. geolocator_android declares a location-typed
         foreground service; with it running, Android keeps location flowing
         while the screen is off, so "while using the app" permission is enough.
         We deliberately do NOT request ACCESS_BACKGROUND_LOCATION — the
         foreground service covers our use and it avoids the Play Store
         background-location review. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <!-- Required by geolocator's enableWakeLock — keeps the CPU awake for GPS
         while the screen is off during a recording. -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <application
        android:label="XC Training Data"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true"
        android:largeHeap="true"><!-- largeHeap: a full 30-day sync moves ~165k HR samples across the method channel; TODO: remove cleartext when server moves to HTTPS -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Health Connect permissions rationale activity -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE"/>
                <category android:name="android.intent.category.HEALTH_PERMISSIONS"/>
            </intent-filter>
        </activity-alias>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Required to detect Health Connect availability -->
        <package android:name="com.google.android.apps.healthdata" />
    </queries>
</manifest>
